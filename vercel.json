{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://berry-oy9z.onrender.com/api/:path*"
    },
    {
      "source": "/oauth2/authorization/:path*",
      "destination": "https://berry-oy9z.onrender.com/oauth2/authorization/:path*"
    },
    {
      "source": "/login/oauth2/code/:path*",
      "destination": "https://berry-oy9z.onrender.com/login/oauth2/code/:path*"
    },
    {
      "source": "/((?!assets/|favicon.svg).*)/",
      "destination": "/index.html"
    },
    {
      "source": "/((?!assets/|favicon.svg).*)",
      "destination": "/index.html"
    }
  ]
}
